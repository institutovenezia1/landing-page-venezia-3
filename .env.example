SUPABASE_URL=https://cvcmvvfobuelmvobsvue.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_publishable_key
# Optional server-side admin key. Use only in Vercel/local env vars, never in frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago Checkout Pro
# Private production token. Server-side only.
MERCADOPAGO_ACCESS_TOKEN=APP_USR-replace_with_production_access_token
# Public production key. Keep available for future frontend SDK usage.
MERCADOPAGO_PUBLIC_KEY=APP_USR-replace_with_production_public_key
# Optional but recommended after registering the webhook in Mercado Pago.
MERCADOPAGO_WEBHOOK_SECRET=

# Public URL used by Mercado Pago for return URLs.
# For local tests use your LocalTunnel URL, for production use the final Vercel URL.
LANDING_BASE_URL=https://your-public-landing-url.example
MERCADOPAGO_WEBHOOK_URL=https://your-public-landing-url.example/api/mercadopago-webhook
